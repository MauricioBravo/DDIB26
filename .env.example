# Copy this file to .env.local for local development (docker compose up
# picks up .env.local automatically, see docker-compose.yml).
#
# Without these, the app still runs end to end: browsing, login, voting UI,
# rankings, everything works. The only two things that need real values are
# blockchain minting and evidence file uploads (Cloudinary) -- without
# them, those two show a clear "not connected" message instead of a broken
# form or a stack trace, by design.
#
# To see the full flow working, either use the live deployment, or ask a
# maintainer for real values:
#   Live demo:  http://161.153.217.84/
#   Repo:       https://github.com/MauricioBravo/DDIB26

# Cardano testnet system signer wallet mnemonic. Signs and submits every
# certification token mint. Testnet only, no real funds. See
# docs/uzh-network.md for the network this points at.
SYSTEM_SIGNER_MNEMONIC=

# Cloudinary unsigned upload preset for evidence photos and documents.
# Not secret in any meaningful sense -- unsigned presets are meant to be
# public and are restricted on Cloudinary's side, not by hiding these.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
